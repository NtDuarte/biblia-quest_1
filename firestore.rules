rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function validUserData() {
      return request.resource.data.keys().hasOnly(['name','email','church','xp','streak','hearts','createdAt','lastActive','lastStudyAt'])
        && (!('name' in request.resource.data) || request.resource.data.name is string && request.resource.data.name.size() <= 30)
        && (!('email' in request.resource.data) || request.resource.data.email is string && request.resource.data.email.size() <= 120)
        && (!('church' in request.resource.data) || request.resource.data.church is string && request.resource.data.church.size() <= 80)
        && (!('xp' in request.resource.data) || request.resource.data.xp is int && request.resource.data.xp >= 0 && request.resource.data.xp <= 1000000)
        && (!('streak' in request.resource.data) || request.resource.data.streak is int && request.resource.data.streak >= 0 && request.resource.data.streak <= 5000)
        && (!('hearts' in request.resource.data) || request.resource.data.hearts is int && request.resource.data.hearts >= 0 && request.resource.data.hearts <= 5);
    }
    function validPublicRank() {
      return request.resource.data.keys().hasOnly(['name','church','xp','streak','lastActive','updatedAt'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 30
        && request.resource.data.church is string && request.resource.data.church.size() <= 80
        && request.resource.data.xp is int && request.resource.data.xp >= 0 && request.resource.data.xp <= 1000000
        && request.resource.data.streak is int && request.resource.data.streak >= 0 && request.resource.data.streak <= 5000
        && request.resource.data.lastActive is string && request.resource.data.lastActive.size() == 10;
    }
    match /users/{uid} {
      allow create: if isOwner(uid) && validUserData();
      allow read, update: if isOwner(uid) && validUserData();
      allow delete: if false;
      match /studies/{studyId} {
        allow read, create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['track','verse','createdAt'])
          && request.resource.data.track is string
          && request.resource.data.track.size() <= 80
          && request.resource.data.verse is string
          && request.resource.data.verse.size() <= 120;
        allow update, delete: if false;
      }
    }
    match /publicRanks/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid) && validPublicRank();
      allow delete: if false;
    }
    match /suggestions/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['text','user','createdAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000;
      allow read, update, delete: if false;
    }
    match /{document=**} { allow read, write: if false; }
  }
}
